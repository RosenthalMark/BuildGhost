#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
APP_DIR="${SCRIPT_DIR}/ghostops-terminal"

usage() {
  cat <<'EOF'
Usage: ghost <command>

Commands:
  start    Start GhostOps Terminal (runs npm start in ghostops-terminal)
  install  Install GhostOps Terminal dependencies
  path     Print GhostOps Terminal path
  help     Show this help
EOF
}

if [[ ! -d "${APP_DIR}" ]]; then
  echo "Error: ghostops-terminal folder not found at: ${APP_DIR}" >&2
  exit 1
fi

cmd="${1:-help}"
shift || true

case "${cmd}" in
  start)
    cd "${APP_DIR}"
    exec npm start "$@"
    ;;
  install)
    cd "${APP_DIR}"
    exec npm install "$@"
    ;;
  path)
    echo "${APP_DIR}"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "Unknown command: ${cmd}" >&2
    usage
    exit 1
    ;;
esac
